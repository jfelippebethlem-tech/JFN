# Environment & secrets
.env
*.env.local

# Browser artifacts
screenshots/
output/

# Binary packages (never commit)
*.deb
*.rpm
*.pkg

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Playwright
playwright/.cache/

# Database (auto-generated at runtime, do not commit binary data)
data/*.db
data/*.db-wal
data/*.db-shm

# Núcleo de Inteligência Progressiva: estado de runtime (calibração/aprendizado),
# não código-fonte. Overrides, feedback, memória e diário são gerados no uso.
data/nucleo_parametros.json
data/nucleo_feedback.json
data/nucleo_evolucao.json
data/nucleo_casos_ouro.json

# Diagnósticos: enviar só .json e .html (estrutura), ignorar screenshots pesados
data/diagnostics/*.png

.env.txt
vm_ssh_key.pem
*.pem
*.pem.txt

# SEI: sessao e dados de processos NUNCA vao pro git (seguranca)
data/tmp/chrome_debug_profile/
data/tmp/
