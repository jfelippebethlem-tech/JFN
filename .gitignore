# Environment & secrets
.env
*.env.local

# Browser artifacts
screenshots/
output/

# Binary packages (never commit)
*.deb
*.rpm
*.pkg

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Playwright
playwright/.cache/

# Database (auto-generated at runtime, do not commit binary data)
data/*.db
data/*.db-wal
data/*.db-shm

# Diagnósticos: enviar só .json e .html (estrutura), ignorar screenshots pesados
data/diagnostics/*.png

.env.txt
vm_ssh_key.pem
*.pem
*.pem.txt

# SEI: sessao e dados de processos NUNCA vao pro git (seguranca)
data/tmp/chrome_debug_profile/
data/tmp/
# sei_cache: excluir dados temporários mas manter dados estruturados de auditoria
data/sei_cache/tfe_*.json
data/sei_cache/siafe_*.json
data/sei_cache/2026*.json
data/sei_cache/SEI-*.json
data/sei_cache/cdp_*.json
data/sei_cache/
**/sessao_cookies.json
data/diagnostics/*.html
data/diagnostics/*.json
data/diagnostics/

# Dependencias JS (reinstalaveis via `npm install`; nunca commitar)
node_modules/

# Relatorios GERADOS em runtime (PDF/XLSX/MD) — nao versionar
/reports/

# Bytecode Python
**/__pycache__/

# Pool de credenciais (8 chaves Gemini etc.) - NUNCA versionar
auth.json
**/auth.json
auth.lock

# bundle gerado (contem segredos) - NUNCA versionar
hermes-tudo.sh
**/hermes-tudo.sh

# Claude Code local settings (permissoes pessoais, nao versionar)
.claude/settings.local.json

# ronda (runtime)
data/ronda.log
data/ronda_state.json

# Massare: DB regenerável via massare.collect --backfill
massare/data/*.db
massare/data/*.db-*

# SIAFE: sessão autenticada e código MFA (nunca versionar)
data/sei_cache/siafe_state.json
data/sei_cache/.mfa_code
data/sei_cache/obs_sessao_*.json

# TFE: CSVs grandes baixados (regeneráveis)
data/tfe_cache/

# SIAFE debug/screenshots
data/sei_cache/siafe_*.png
data/sei_cache/debug_*.txt
data/sei_cache/ERRO_*.png
data/tfe_cache/fornecedor_ob*.zip
data/tfe_cache/fornecedor_ob*.csv

# Benchmark runtime (gerado)
data/benchmark_ias.csv

# Logs e dumps de sessao em runtime (regeneraveis) — nao versionar
data/*.log
data/sessao_*.txt
data/benchmark_resultados.json

# codegraph + graphify: indices locais, regenerados, NAO commitar (diretriz 2026-06-07)
.codegraph/
graphify-out/
