# === Produção: Mestre Yoda via OpenRouter (GRATUITO, sem chave Anthropic) ===
# Use este modelo quando NÃO tiver ANTHROPIC_API_KEY. O bot fala com modelos
# ":free" do OpenRouter (mesmo provedor que o Hermes já usa).
#
#   cp .env.openrouter.example .env
#   # preencha TELEGRAM_BOT_TOKEN e OPENROUTER_API_KEY
#   docker compose up -d --build

# --- Segredos (preencher os DOIS) ---
TELEGRAM_BOT_TOKEN=
# Chave gratuita em https://openrouter.ai/keys (começa com sk-or-v1-...)
OPENROUTER_API_KEY=

# --- Provedor e modelo (gratuito) ---
# Modelo atual do bot. Outros grátis: nousresearch/hermes-3-llama-3.1-405b:free,
# qwen/qwen-2.5-72b-instruct:free, google/gemma-2-9b-it:free
OPENROUTER_SMART_MODEL=stepfun/step-3.7-flash:free
# (opcional) força o provedor; sem isso, é detectado pela chave presente.
# YODA_PROVIDER=openrouter

# --- Busca na web ---
# Modelos :free não têm web_search server-side; o bot desliga sozinho.
# As cotações reais (yfinance) seguem funcionando na rotina BOM DIA.
YODA_ENABLE_WEB_SEARCH=false

# --- Memória ---
YODA_MAX_HISTORY=20
YODA_SUMMARY_BUFFER=10

# --- Resiliência (modelos grátis dão 429 com frequência; mais retries ajuda) ---
YODA_MAX_RETRIES=4
YODA_RETRY_BASE_DELAY=1.0

# --- Acesso: só o chat do Mestre Jorge ---
YODA_ALLOWED_CHAT_IDS=45338178

# --- Rotina diária "BOM DIA do Mestre Jorge" ---
YODA_BRIEFING_ENABLED=true
YODA_BRIEFING_CHAT_ID=45338178
YODA_BRIEFING_TIME=07:30
YODA_BRIEFING_TIMEZONE=America/Sao_Paulo

# --- Atualização via /atualizar ---
YODA_REPO_PATH=/app

# --- Log ---
YODA_LOG_LEVEL=INFO
