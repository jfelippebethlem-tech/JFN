# === Credenciais obrigatórias ===
# Token do bot, obtido com o @BotFather no Telegram.
TELEGRAM_BOT_TOKEN=

# Chave da API do Claude (https://console.anthropic.com/).
ANTHROPIC_API_KEY=

# === Opcional ===
# Modelo do Claude usado pelo Hermes.
ANTHROPIC_MODEL=claude-opus-4-8

# Caminho do banco SQLite de memória.
YODA_DB_PATH=yoda_memory.db

# Esforço de raciocínio: low | medium | high | xhigh | max
YODA_EFFORT=high

# Quantas mensagens manter antes de resumir a conversa.
YODA_MAX_HISTORY=20

# Busca na web (o Yoda responde sobre fatos atuais). true | false
YODA_ENABLE_WEB_SEARCH=true

# Restrição de acesso: chat IDs separados por vírgula. Vazio = todos liberados.
YODA_ALLOWED_CHAT_IDS=

# Nível de log: DEBUG | INFO | WARNING | ERROR
YODA_LOG_LEVEL=INFO

# === Rotina diária "BOM DIA do Mestre Jorge" ===
# Liga o envio automático da rotina matinal. true | false
YODA_BRIEFING_ENABLED=false

# Chat que recebe a rotina (obrigatório quando ENABLED=true).
YODA_BRIEFING_CHAT_ID=

# Horário de envio, HH:MM (24h).
YODA_BRIEFING_TIME=07:00

# Fuso horário do horário acima.
YODA_BRIEFING_TIMEZONE=America/Sao_Paulo
