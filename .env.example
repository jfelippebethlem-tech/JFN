# ============================================================
# .env.example — Copie para .env e preencha com seus dados
# NUNCA envie o .env para o git (.gitignore já protege)
# ============================================================

# ── LLM (OBRIGATÓRIO — pelo menos um) ───────────────────────
# Groq: crie conta grátis em https://console.groq.com
GROQ_API_KEY=gsk_COLE_SUA_CHAVE_AQUI

# OpenRouter: alternativa gratuita em https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-COLE_SUA_CHAVE_AQUI
OPENROUTER_SMART_MODEL=nousresearch/hermes-3-llama-3.1-405b:free
OPENROUTER_FAST_MODEL=google/gemma-2-9b-it:free

# Qual usar primeiro: groq | openrouter | ollama
FREE_LLM_PREFER=groq

# ── Claude API (opcional, pago) ──────────────────────────────
ANTHROPIC_API_KEY=

# ── Telegram (opcional — alertas no celular) ─────────────────
TELEGRAM_BOT_TOKEN=SEU_TOKEN_DO_BOT
TELEGRAM_CHAT_ID=SEU_CHAT_ID

# ── SIAFE2 (só funciona na rede interna do governo RJ) ───────
SIAFE_USER=SEU_CPF_SEM_PONTOS
SIAFE_PASS=SUA_SENHA_SIAFE

# ── Configurações opcionais ───────────────────────────────────
SIAFE_CLIENTE=
SIAFE_EXERCICIO=
OLLAMA_MODEL=llama3.2:3b
MONTHLY_TOKEN_LIMIT=500000
TRANSPARENCIA_API_KEY=
HERMES_MAX_TOKENS=8000
SEI_CAPTCHA_TENTATIVAS=4
# SEI interno (login autenticado — contorna a pesquisa pública WAF/CAPTCHA).
# IMPORTANTE: usuário em MINÚSCULAS ('itkava'). Rodar de IP gov/permitido — o WAF do SEI-RJ
# bloqueia o IP da VM (GCP) ATÉ na tela de login.
SEI_USER=itkava
SEI_PASS=
SEI_ORGAO=
SEI_LOGIN_URL=https://sei.rj.gov.br/sip/login.php?sigla_sistema=SEI
AUDITOR_24H_INTERVALO=1800

# Bot-convidado do Yoda (multiusuário SEGURO — read-only, sem shell). Token de um bot SEPARADO (@BotFather),
# NUNCA o token do bot admin. TELEGRAM_GUEST_USERS = IDs do Telegram autorizados, separados por vírgula.
TELEGRAM_BOT_TOKEN_GUEST=
TELEGRAM_GUEST_USERS=

# ── Onda 12: providers OSINT gratuitos (todos ungated salvo OpenSanctions) ──
# Registro de empresa (cadeia; 1º que responder vence). Bases ungated confirmadas ao vivo.
BRASILAPI_BASE=https://brasilapi.com.br/api/cnpj/v1
OPENCNPJ_BASE=https://api.opencnpj.org
CNPJWS_BASE=https://publica.cnpj.ws/cnpj
# Sanções/PEP/vazamentos (chave grátis p/ uso não comercial; opcional — sem ela usa busca pública)
OPENSANCTIONS_API_KEY=
OPENSANCTIONS_BASE=https://api.opensanctions.org
# Diários oficiais municipais (Querido Diário — sem chave). Base do spec (queridodiario.ok.org.br/api)
# está atrás de Cloudflare; a que funciona é api.queridodiario.ok.org.br.
QUERIDODIARIO_BASE=https://api.queridodiario.ok.org.br
# TSE doador×contrato (dados abertos em massa — CKAN). Só o subconjunto RJ é persistido.
TSE_DADOS_BASE=https://dadosabertos.tse.jus.br
