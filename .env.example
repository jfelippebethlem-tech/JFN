# Authentication
AUTH_SECRET=your-super-secret-key-here-change-this
ADMIN_PASSWORD=admin123

# Deputy Info
DEPUTY_NAME="Dep. João Silva"
DEPUTY_PARTY="PT"
DEPUTY_STATE="SP"

# AI Principal (Google Gemini - GRATUITO em aistudio.google.com)
# 1.500 req/dia grátis, sem cartão de crédito
GEMINI_API_KEY=your-gemini-api-key

# Hermes Agent (OpenRouter - GRATUITO em openrouter.ai)
# Usa Hermes 3 405B (NousResearch) — melhor modelo para agentes
# Fallback automático para Gemini se não configurado
OPENROUTER_API_KEY=your-openrouter-api-key

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Bond Agent — Redes Sociais do Deputado
# Twitter/X API v2 (free at developer.twitter.com)
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_USERNAME=seu_usuario_twitter

# Facebook Page (Graph API - free at developers.facebook.com)
# Precisa de uma Página do Facebook (não perfil pessoal)
FACEBOOK_PAGE_TOKEN=your-facebook-page-access-token

# Instagram é automaticamente conectado via FACEBOOK_PAGE_TOKEN
# (precisa de conta Business/Creator vinculada à Página)

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
