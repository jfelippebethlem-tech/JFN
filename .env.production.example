# === Produção: Mestre Yoda (Mestre Jorge) ===
# Copie para .env e preencha os DOIS segredos abaixo. O resto já vem pronto
# para o setup do Mestre Jorge (rotina BOM DIA às 7h, fuso do Rio).
#
#   cp .env.production.example .env
#   # preencha TELEGRAM_BOT_TOKEN e ANTHROPIC_API_KEY
#   docker compose up -d --build

# --- Segredos (preencher) ---
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=

# --- Claude / Hermes ---
ANTHROPIC_MODEL=claude-opus-4-8
YODA_EFFORT=high

# --- Memória ---
YODA_MAX_HISTORY=20
YODA_SUMMARY_BUFFER=10

# --- Resiliência ---
YODA_MAX_RETRIES=3
YODA_RETRY_BASE_DELAY=0.5

# --- Busca na web (notícias e clima da rotina) ---
YODA_ENABLE_WEB_SEARCH=true

# --- Acesso: só o chat do Mestre Jorge ---
YODA_ALLOWED_CHAT_IDS=45338178

# --- Rotina diária "BOM DIA do Mestre Jorge" ---
YODA_BRIEFING_ENABLED=true
YODA_BRIEFING_CHAT_ID=45338178
YODA_BRIEFING_TIME=07:00
YODA_BRIEFING_TIMEZONE=America/Sao_Paulo

# --- Log ---
YODA_LOG_LEVEL=INFO
