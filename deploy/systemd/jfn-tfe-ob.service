[Unit]
Description=JFN — base completa de OBs (download TFE + ingestão 2019-2026)
After=network-online.target
[Service]
Type=oneshot
WorkingDirectory=%h/JFN
Environment=JFN_DATA_DIR=%h/JFN/data
ExecStart=%h/JFN/.venv/bin/python -m compliance_agent.collectors.tfe_ob --baixar
ExecStartPost=/bin/bash -lc 'for a in 2019 2020 2021 2022 2023 2024 2025 2026; do %h/JFN/.venv/bin/python -m compliance_agent.collectors.tfe_ob --ano $a --ingest; done'
