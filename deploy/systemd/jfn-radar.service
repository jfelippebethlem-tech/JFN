[Unit]
Description=JFN — Radar 24/7 (vigilância preventiva: PNCP aberto restritivo + OB anômala → alerta Telegram)
After=jfn.service

[Service]
Type=oneshot
WorkingDirectory=%h/JFN
Environment=JFN_DATA_DIR=%h/JFN/data
Environment=PYTHONPATH=%h/JFN
ExecStart=%h/JFN/.venv/bin/python -m compliance_agent.radar
